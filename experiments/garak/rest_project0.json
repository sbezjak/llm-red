{
  "rest": {
    "RestGenerator": {
      "name": "project0-ask-asis",
      "uri": "http://localhost:8000/ask",
      "method": "post",
      "headers": { "Content-Type": "application/json" },
      "req_template_json_object": { "question": "$INPUT" },
      "response_json": true,
      "response_json_field": "answer",
      "request_timeout": 120
    }
  }
}
